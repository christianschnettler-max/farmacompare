{
  "name": "farmacompare",
  "type": "module",
  "version": "1.0.0",
  "description": "Comparador de precios de medicamentos en farmacias chilenas",
  "main": "main.js",
  "author": "FarmaCompare Chile",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "cl.farmacompare.app",
    "productName": "FarmaCompare Chile",
    "asar": false,
    "directories": { "output": "dist-electron" },
    "extraResources": [
      { "from": "../backend", "to": "backend", "filter": ["**/*", "!node_modules/.cache", "!tests"] },
      { "from": "../frontend/dist", "to": "frontend/dist" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FarmaCompare Chile"
    }
  }
}
